{
  "name": "@chest-backup/monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @chest-backup/api dev & pnpm --filter @chest-backup/web dev",
    "dev:api": "pnpm --filter @chest-backup/api dev",
    "dev:web": "pnpm --filter @chest-backup/web dev",
    "build": "pnpm -r --filter '!@chest-backup/app' build",
    "build:api": "pnpm --filter @chest-backup/api build",
    "build:web": "pnpm --filter @chest-backup/web build",
    "start": "pnpm --filter @chest-backup/app start",
    "lint": "eslint apps/ src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
