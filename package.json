{
  "name": "@chest-backup/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:api": "bun --watch apps/api/src/index.ts",
    "dev:web": "cd apps/web && pnpm dev",
    "build": "tsc",
    "build:api": "cd apps/api && pnpm build",
    "build:web": "cd apps/web && pnpm build",
    "start": "systemctl --user start chest-backup",
    "stop": "systemctl --user stop chest-backup",
    "status": "systemctl --user status chest-backup",
    "restart": "systemctl --user restart chest-backup",
    "start:now": "bun src/index.ts -- --run-now",
    "start:dry": "bun src/index.ts -- --dry-run",
    "test": "bun test --bail --timeout 120000 --path-ignore-patterns 'dist/**'",
    "test:unit": "bun test --bail --path-ignore-patterns 'dist/**' test/unit/",
    "test:e2e": "docker compose -f docker-compose.test.yaml down --remove-orphans && docker compose -f docker-compose.test.yaml build test-runner && docker compose -f docker-compose.test.yaml run --rm test-runner && docker compose -f docker-compose.test.yaml down --remove-orphans",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@trayjs/linux-x64": "^0.0.10",
    "@trayjs/trayjs": "^0.0.10",
    "cron-parser": "^5.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
