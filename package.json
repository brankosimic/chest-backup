{
  "name": "@chest-backup/app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "docker compose up",
    "start:now": "docker compose build && docker compose run --rm chest-backup -- --run-now",
    "start:dry": "docker compose run --rm chest-backup -- --dry-run",
    "test": "bun test --bail --timeout 120000 --path-ignore-patterns 'dist/**'",
    "test:unit": "bun test --bail --path-ignore-patterns 'dist/**' test/unit/",
    "test:e2e": "docker compose -f docker-compose.test.yaml down --remove-orphans && docker compose -f docker-compose.test.yaml build test-runner && docker compose -f docker-compose.test.yaml run --rm test-runner && docker compose -f docker-compose.test.yaml down --remove-orphans",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "cron-parser": "^5.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/ssh2-sftp-client": "^9.0.6",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
