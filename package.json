{
  "name": "@chest-backup/app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun src/index.ts",
    "test": "bun test --bail --timeout 120000 --path-ignore-patterns 'dist/**'",
    "test:unit": "bun test --bail --path-ignore-patterns 'dist/**' test/unit/",
    "test:e2e": "bun test --bail --path-ignore-patterns 'dist/**' test/e2e/",
    "test:container": "docker compose -f docker-compose.test.yaml down --remove-orphans && docker compose -f docker-compose.test.yaml build test-runner && docker compose -f docker-compose.test.yaml run --rm test-runner",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "cron-parser": "^5.0.1",
    "basic-ftp": "^5.0.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "prettier": "^3.4.0"
  }
}
