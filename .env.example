# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# FTP credentials (referenced in chest-backup.json as ${FTP_PASSWORD})
FTP_PASSWORD=changeme

# Database password
DB_PASSWORD=changeme

# Discord webhook parts (referenced as ${WEBHOOK_ID} and ${WEBHOOK_TOKEN})
WEBHOOK_ID=your_webhook_id
WEBHOOK_TOKEN=your_webhook_token
